# Development Configuration

# Optional: Token for CLI/script access to API (development only)
# Generate a random string: openssl rand -hex 16
QUJE_DEV_TOKEN=your-dev-token-here

# Optional: Ollama configuration
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: ComfyUI configuration
# COMFYUI_URL=http://localhost:8188

# Optional: Brave Search API key (for web search tool)
# BRAVE_API_KEY=your-brave-api-key-here

# Optional: Exa Search API key (alternative web search provider)
# EXA_API_KEY=your-exa-api-key-here

# Optional: RP_ID for WebAuthn (defaults to request hostname)
# RP_ID=localhost

# Optional: ORIGIN for WebAuthn (defaults to request origin)
# ORIGIN=http://localhost:5174

# Optional: TTS Python interpreter overrides.
# Prefer backend-specific overrides so one backend's venv does not break the others.
# The helper script writes these to server/.env.tts:
#   ./scripts/install-tts-backend.sh kokoro
#   ./scripts/install-tts-backend.sh qwen3-tts
#   ./scripts/install-tts-backend.sh supertonic-3
# KOKORO_TTS_PYTHON_OVERRIDE=/path/to/kokoro/.venv/bin/python
# QWEN3_TTS_PYTHON_OVERRIDE=/path/to/qwen3/.venv/bin/python
# SUPERTONIC_TTS_PYTHON_OVERRIDE=/path/to/supertonic/.venv/bin/python
# TTS_PYTHON_OVERRIDE=/path/to/shared/.venv/bin/python
# Optional Supertonic pitch processor: resample (cleaner default) or rubberband.
# SUPERTONIC_TTS_PITCH_PROCESSOR=resample
